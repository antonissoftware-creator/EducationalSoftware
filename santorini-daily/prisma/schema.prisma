generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String        @id @default(cuid())
  email             String        @unique
  passwordHash      String        @map("password_hash")
  name              String
  preferredLanguage String        @default("en") @map("preferred_language")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  quizAttempts      QuizAttempt[]
  progressRecords   Progress[]
  favorites         Favorite[]
  bookmarks         Bookmark[]
  settings          UserSettings?
  sessions          Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model GuestSession {
  id           String       @id @default(cuid())
  sessionToken String       @unique @map("session_token")
  createdAt    DateTime     @default(now()) @map("created_at")
  lastSeenAt   DateTime     @default(now()) @map("last_seen_at")
  quizAttempts QuizAttempt[]
  progress     Progress[]

  @@map("guest_sessions")
}

model Module {
  id               String          @id @default(cuid())
  slug             String          @unique
  titleEl          String          @map("title_el")
  titleEn          String          @map("title_en")
  descriptionEl    String          @map("description_el")
  descriptionEn    String          @map("description_en")
  orderIndex       Int             @map("order_index")
  difficulty       String
  estimatedMinutes Int             @map("estimated_minutes")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  sections         ModuleSection[]
  quizzes          Quiz[]
  places           Place[]
  progress         Progress[]
  bookmarks        Bookmark[]

  @@map("modules")
}

model ModuleSection {
  id          String   @id @default(cuid())
  moduleId    String   @map("module_id")
  titleEl     String   @map("title_el")
  titleEn     String   @map("title_en")
  contentEl   String   @map("content_el")
  contentEn   String   @map("content_en")
  mediaType   String   @map("media_type")
  mediaUrl    String?  @map("media_url")
  orderIndex  Int      @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  bookmarks   Bookmark[]

  @@map("module_sections")
}

model Place {
  id              String   @id @default(cuid())
  titleEl         String   @map("title_el")
  titleEn         String   @map("title_en")
  descriptionEl   String   @map("description_el")
  descriptionEn   String   @map("description_en")
  category        String
  latitude        Float
  longitude       Float
  imageUrl        String?  @map("image_url")
  relatedModuleId String?  @map("related_module_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  relatedModule   Module?  @relation(fields: [relatedModuleId], references: [id])
  favorites       Favorite[]

  @@map("places")
}

model Quiz {
  id        String       @id @default(cuid())
  moduleId  String?      @map("module_id")
  titleEl   String       @map("title_el")
  titleEn   String       @map("title_en")
  type      String
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  module    Module?      @relation(fields: [moduleId], references: [id])
  questions Question[]
  attempts  QuizAttempt[]

  @@map("quizzes")
}

model Question {
  id            String           @id @default(cuid())
  quizId         String           @map("quiz_id")
  questionEl     String           @map("question_el")
  questionEn     String           @map("question_en")
  type           String
  category       String
  difficulty     String
  explanationEl  String           @map("explanation_el")
  explanationEn  String           @map("explanation_en")
  imageUrl       String?          @map("image_url")
  orderIndex     Int              @map("order_index")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  quiz           Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options        QuestionOption[]
  userAnswers    UserAnswer[]

  @@map("questions")
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String   @map("question_id")
  textEl     String   @map("text_el")
  textEn     String   @map("text_en")
  isCorrect  Boolean  @map("is_correct")
  orderIndex Int      @map("order_index")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_options")
}

model QuizAttempt {
  id               String       @id @default(cuid())
  userId           String?      @map("user_id")
  guestSessionId   String?      @map("guest_session_id")
  quizId           String       @map("quiz_id")
  score            Float
  totalQuestions   Int          @map("total_questions")
  correctAnswers   Int          @map("correct_answers")
  startedAt        DateTime     @default(now()) @map("started_at")
  completedAt      DateTime?    @map("completed_at")
  timeSpentSeconds Int          @default(0) @map("time_spent_seconds")
  user             User?        @relation(fields: [userId], references: [id])
  guestSession     GuestSession? @relation(fields: [guestSessionId], references: [id])
  quiz             Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers          UserAnswer[]

  @@map("quiz_attempts")
}

model UserAnswer {
  id               String        @id @default(cuid())
  quizAttemptId    String        @map("quiz_attempt_id")
  questionId       String        @map("question_id")
  selectedOptionId String?       @map("selected_option_id")
  isCorrect        Boolean       @map("is_correct")
  answeredAt       DateTime      @default(now()) @map("answered_at")
  quizAttempt      QuizAttempt   @relation(fields: [quizAttemptId], references: [id], onDelete: Cascade)
  question         Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("user_answers")
}

model Progress {
  id                   String       @id @default(cuid())
  userId               String?      @map("user_id")
  guestSessionId       String?      @map("guest_session_id")
  moduleId             String       @map("module_id")
  completedSections    Int          @default(0) @map("completed_sections")
  completionPercentage Float        @default(0) @map("completion_percentage")
  lastVisitedAt        DateTime     @default(now()) @map("last_visited_at")
  isCompleted          Boolean      @default(false) @map("is_completed")
  user                 User?        @relation(fields: [userId], references: [id])
  guestSession         GuestSession? @relation(fields: [guestSessionId], references: [id])
  module               Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@unique([guestSessionId, moduleId])
  @@map("progress")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  placeId   String   @map("place_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
  @@map("favorites")
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  moduleId  String   @map("module_id")
  sectionId String?  @map("section_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  section   ModuleSection? @relation(fields: [sectionId], references: [id])

  @@map("bookmarks")
}

model UserSettings {
  id                  String   @id @default(cuid())
  userId              String   @unique @map("user_id")
  geminiApiKeyEncrypted String? @map("gemini_api_key_encrypted")
  aiEnabled           Boolean  @default(false) @map("ai_enabled")
  language            String   @default("en")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}
